# ── Server ───────────────────────────────────────────────────
PORT=8000
DEBUG=true

# ── MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=mathurapharmeasy

# ── JWT ──────────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_64_char_random_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ══════════════════════════════════════════════════════════════
#  💳  RAZORPAY — https://razorpay.com → Settings → API Keys
# ══════════════════════════════════════════════════════════════
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── App ──────────────────────────────────────────────────────
APP_URL=http://localhost:8000
UPLOAD_DIR=./public/uploads
FRONTEND_URL=http://localhost:5173

# ══════════════════════════════════════════════════════════════
#  📧  EMAIL (SMTP) — Transactional order notifications
#  Gmail: enable 2-FA → generate an App Password at
#         https://myaccount.google.com/apppasswords
#  Use SMTP_PASSWORD = the 16-char app password (not your Gmail password)
# ══════════════════════════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
FROM_EMAIL=your_gmail@gmail.com
FROM_NAME=MathuraPharmeasy

# ══════════════════════════════════════════════════════════════
#  📱  SMS (Fast2SMS — India)
#  Sign up at https://www.fast2sms.com → Developer → API
#  Copy the API key from the dashboard.
#  For production use the DLT route with registered templates.
# ══════════════════════════════════════════════════════════════
FAST2SMS_API_KEY=your_fast2sms_api_key_here
